# ------------------------------------------------------------
# MANDARA_GIS - Git ignore rules
# Windows + Visual Studio 2026 + VB / WinForms
# ------------------------------------------------------------

# ------------------------------------------------------------
# Visual Studio user / workspace files
# ------------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# ------------------------------------------------------------
# Build outputs
# ------------------------------------------------------------
[Dd]ebug/
[Rr]elease/
x86/
x64/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# ------------------------------------------------------------
# Cache / temporary files
# ------------------------------------------------------------
*.cache
!?*.[Cc]ache/
*.log
*.tmp
*.tmp_proj
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.pidb
*.svclog

# ------------------------------------------------------------
# Visual Studio / MSBuild generated reports and backups
# ------------------------------------------------------------
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.rptproj.bak
*.builds

# ------------------------------------------------------------
# Source control binding / legacy IDE files
# ------------------------------------------------------------
*.vspscc
*.vssscc
*.scc

# ------------------------------------------------------------
# Visual Studio profiler
# ------------------------------------------------------------
*.psess
*.vsp
*.vspx
*.sap

# ------------------------------------------------------------
# ReSharper
# ------------------------------------------------------------
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ------------------------------------------------------------
# VS Code
# ------------------------------------------------------------
.vscode/

# ------------------------------------------------------------
# Windows / macOS filesystem noise
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store

# ------------------------------------------------------------
# NuGet
# Keep current packages folder strategy for now.
# Do not ignore packages/ until PackageReference migration is done.
# ------------------------------------------------------------
*.nupkg
*.snupkg

# ------------------------------------------------------------
# MANDARA-specific generated / runtime data
# Adjust later if some of these must be versioned.
# ------------------------------------------------------------
*.mdx
*.mda
